# --- Express notification server ---
PORT=8080
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=changeme
MAIL_FROM="QMR Document Delivery <qmr@hospital.go.th>"

# --- Firebase (frontend, optional) ---
# Leave blank to keep using the in-memory mock store.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Claude / Anthropic (AI drafting) ---
# In the demo the key is entered in-app (Studio → ตั้งค่า AI) and kept in the
# browser's localStorage. For production, proxy calls through the server and
# read the key here instead of exposing it to the browser.
ANTHROPIC_API_KEY=
